# ============================================
# SARA BOT - ENVIRONMENT VARIABLES TEMPLATE
# ============================================
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env file to git!

# ============================================
# GOOGLE GEMINI API
# ============================================
# Get your key from: https://aistudio.google.com/app/apikeys
# Used for: General chat, explanations, and responses
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# OPENAI API
# ============================================
# Get your key from: https://platform.openai.com/account/api-keys
# Used for: Coding tasks and technical questions
# Note: Requires billing to be enabled on your account
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# FLASK CONFIGURATION
# ============================================
# Options: development, production, testing
FLASK_ENV=development

# ============================================
# OPTIONAL SETTINGS
# ============================================
# Uncomment and modify as needed

# Flask debug mode (only for development)
# FLASK_DEBUG=True

# Flask host and port
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5000

# API timeout in seconds
# API_TIMEOUT=60

# Max tokens for API responses
# MAX_TOKENS=1000
